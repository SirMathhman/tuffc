{
  "name": "tuffc",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --format cjs,esm --minify",
    "find-duplicates": "pmd cpd --dir src,tests --language typescript --minimum-tokens 35 --ignore-literals --ignore-identifiers || exit 2",
    "lint": "eslint . --ext ts || exit 2",
    "test": "bun test || exit 2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
