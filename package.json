{
  "name": "tuffc",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "jest",
    "lint": "eslint src tests",
    "start": "node dist/index.js",
    "clean": "rimraf dist",
    "find-duplicates:token": "pmd cpd --dir src,tests --language typescript --minimum-tokens 35 --ignore-identifiers",
    "precommit": "npm test && npm run find-duplicates:token"
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^8.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "eslint": "^9.0.0",
    "jest": "^30.0.0",
    "ts-jest": "^29.4.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.2"
  }
}
