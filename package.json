{
  "name": "tuffc",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run src/index.ts",
    "test": "bun test --coverage --coverage-threshold=100",
    "typecheck": "bun x tsc --noEmit",
    "find-duplicates": "pmd cpd --dir src test --language typescript --minimum-tokens 50 --ignore-literals --ignore-identifiers"
  },
  "devDependencies": {
    "bun-types": "^1.2.0",
    "typescript": "^5.8.3"
  }
}
