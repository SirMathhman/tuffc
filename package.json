{
  "name": "tuffc",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "dev": "ts-node src/cli.ts",
    "lint": "eslint . --ext .ts",
    "test": "jest",
    "cpd": "pmd cpd --dir src --dir tests --language typescript --ignore-identifiers --minimum-tokens 35",
    "prepare": "husky && git config core.hooksPath .husky"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "@types/jest": "^29.5.3",
    "husky": "^9.0.0",
    "lint-staged": "^14.0.0"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx}": [
      "eslint --fix"
    ]
  }
}
