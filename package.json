{
  "name": "tuffc",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.2.0",
  "scripts": {
    "dev": "bun run src/index.ts",
    "test": "bun test",
    "build": "bunx tsc -p tsconfig.json",
    "lint": "bunx tsc --noEmit",
    "check": "bun run test && bun run lint && bun run find-duplicates",
    "start": "bun run dist/index.js",
    "prepare": "husky",
    "find-duplicates": "pmd cpd --dir src,tests --minimum-tokens 40 --language typescript --format markdown --ignore-literals --ignore-identifiers"
  },
  "devDependencies": {
    "bun-types": "latest",
    "typescript": "^5.8.3"
  }
}
