{
  "name": "tuffc",
  "type": "module",
  "private": true,
  "scripts": {
    "convert-templates": "bun scripts/convert-templates.ts",
    "build": "bun build src/index.ts --outdir dist --format cjs,esm --minify",
    "find-duplicates": "pmd cpd --dir src,tests --language typescript --minimum-tokens 35 --ignore-literals --ignore-identifiers || exit 2",
    "lint": "eslint . --ext ts || exit 2",
    "refactor:compile:capture": "bun scripts/refactor/split-compile.ts capture",
    "refactor:compile:split": "bun scripts/refactor/split-compile.ts all",
    "test": "bun test || exit 2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "ts-morph": "^27.0.2",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
