{
  "name": "tuffc",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.2.0",
  "scripts": {
    "dev": "bun run src/index.ts",
    "test": "bun test",
    "build": "bunx tsc -p tsconfig.json",
    "lint": "eslint .",
    "lint:eslint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "bunx tsc --noEmit",
    "check": "bun run test && bun run typecheck && bun run find-duplicates",
    "start": "bun run dist/index.js",
    "prepare": "husky",
    "find-duplicates": "pmd cpd --dir src,tests --minimum-tokens 40 --language typescript --format markdown --ignore-literals --ignore-identifiers"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "bun-types": "latest",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.57.2"
  }
}
