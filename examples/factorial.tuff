// Factorial - demonstrates functions, loops, and arithmetic
fn factorial(n: i32) -> i32 {
    let result: i32 = 1;
    let i: i32 = 1;
    while i <= n {
        result = result * i;
        i = i + 1;
    }
    return result;
}

fn main() -> i32 {
    let fact5: i32 = factorial(5);
    // Should return 120
    return fact5;
}
