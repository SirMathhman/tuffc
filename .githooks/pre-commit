#!/usr/bin/env python3
"""
Pre-commit hook: prevent committing files over 500 lines.

Checks the staged (added/modified) files and fails commit with a clear
message when any staged file has more than 500 lines. The message tells
the author that the file MUST be split up into multiple files.
"""
import os
import subprocess
import sys


def staged_files():
    out = subprocess.check_output(
        ["git", "diff", "--cached", "--name-only", "--diff-filter=AM"]
    )
    return [p for p in out.decode().splitlines() if p]


def count_lines(path: str) -> int:
    try:
        with open(path, "rb") as f:
            return sum(1 for _ in f)
    except OSError:
        return 0


def main() -> int:
    files = staged_files()
    blocked = []
    for f in files:
        # Skip paths that are not in the working tree (deleted or submodules)
        if not os.path.isfile(f):
            continue

        lines = count_lines(f)
        if lines > 500:
            blocked.append((f, lines))

    if blocked:
        print("Commit blocked: one or more staged files exceed 500 lines:\n")
        for path, lines in blocked:
            print(f" - {path}: {lines} lines (MUST be split up into multiple files)")

        print("\nPlease split large files into smaller modules before committing.")
        return 1

    return 0


if __name__ == "__main__":
    sys.exit(main())
