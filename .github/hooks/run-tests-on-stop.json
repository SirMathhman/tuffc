{
  "hooks": {
    "Stop": [
      {
        "type": "command",
        "windows": "powershell -File .github/hooks/scripts/run-tests.ps1",
        "timeout": 30
      },
      {
        "type": "command",
        "windows": "powershell -File .github/hooks/scripts/run-lint.ps1",
        "timeout": 30
      },
      {
        "type": "command",
        "windows": "powershell -File .github/hooks/scripts/run-single-use.ps1",
        "timeout": 30
      },
      {
        "type": "command",
        "windows": "powershell -File .github/hooks/scripts/run-cpd.ps1",
        "timeout": 30
      }
    ]
  }
}
