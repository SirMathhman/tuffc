{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "configure",
      "type": "shell",
      "command": "cmake",
      "args": ["-S", ".", "-B", "build"],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "build",
      "type": "shell",
      "command": "cmake",
      "args": ["--build", "build", "--config", "Debug"],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "test",
      "type": "shell",
      "command": "ctest",
      "args": ["--test-dir", "build", "-C", "Debug", "--output-on-failure"],
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "lint",
      "type": "shell",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "scripts/lint.ps1"
      ],
      "problemMatcher": []
    },
    {
      "label": "check-duplicates",
      "type": "shell",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "scripts/check-duplicates.ps1"
      ],
      "problemMatcher": []
    },
    {
      "label": "verify",
      "type": "shell",
      "command": "echo",
      "args": ["Verification complete"],
      "dependsOn": ["configure", "build", "test", "lint", "check-duplicates"],
      "dependsOrder": "sequence",
      "problemMatcher": []
    }
  ]
}
